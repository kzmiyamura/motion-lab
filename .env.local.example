# YouTube Data API v3 キー
# 取得方法:
#   1. https://console.cloud.google.com/ にアクセス
#   2. プロジェクト作成 → 「YouTube Data API v3」を有効化
#   3. 認証情報 → APIキー作成
#   4. APIキーの制限: 「HTTPリファラー」でドメインを制限することを推奨
#
# ローカル開発: このファイルを .env.local にコピーして値を設定
# Cloudflare Pages: ダッシュボード → Settings → Environment Variables に追加
VITE_YOUTUBE_API_KEY=your_api_key_here

# Google OAuth2 クライアントID（Files タブ → Google Drive 連携用）
# 取得方法:
#   1. https://console.cloud.google.com/ → 認証情報 → 「OAuth 2.0 クライアント ID」作成
#   2. アプリの種類: 「ウェブ アプリケーション」
#   3. 承認済みの JavaScript 生成元に追加:
#      - http://localhost:5173
#      - https://motion-lab-apa.pages.dev
#   4. Google Drive API を有効化
#   5. OAuth 同意画面でスコープ「drive.readonly」を追加
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
